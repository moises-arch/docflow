# ════════════════════════════════════════════════════════════════════════════
# DocFlow — Environment variables
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local for local development, OR configure these in
# your hosting provider's environment settings for production.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Everything else is server-side only.
# ════════════════════════════════════════════════════════════════════════════


# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL where the app is hosted. Used for absolute links in emails, scan
# QR codes, OAuth redirects, etc. In production set this to your domain.
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development

# Base URL of the external ERP, used to build deep links to sales orders.
NEXT_PUBLIC_ERP_BASE_URL=https://erp.example.com


# ─── Supabase (Database / Auth / Storage / Edge Functions) ────────────────────
# Public — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server only — NEVER expose. Used by API routes for service-role operations.
SUPABASE_SERVICE_ROLE_KEY=

# Optional aliases (some legacy code paths use these).
# Leave empty unless you know you need them.
INTAKE_SUPABASE_URL=
INTAKE_SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=


# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Random secret used to authenticate cron requests. Generate with:
#   openssl rand -hex 32
CRON_SECRET=


# ─── Public scanner (QR upload links) ─────────────────────────────────────────
# HMAC secret for signing the public scanner tokens. Generate with:
#   openssl rand -hex 32
SCAN_TOKEN_SECRET=


# ─── Email provider (inbox ingestion, optional) ──────────────────────────────
# Required only if a tenant ingests purchase orders from an email inbox.
# Per-tenant overrides in the DB take precedence over these globals.
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
# Default "from" address used for outbound notifications.
M365_SEND_FROM_ADDRESS=orders@example.com


# ─── Sentry (error reporting, optional) ───────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=


# ─── Browser-scrape runtime (optional, for scraping connectors) ───────────────
# Local override for the Chromium binary used by the scraper.
# Serverless platforms use a Lambda-compatible Chromium automatically.
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=


# ─── Supplier Portal connector (EDI / PO download, optional) ──────────────────
# Credentials for the portal runner that downloads purchase orders.
CLEO_USERNAME=
CLEO_PASSWORD=
# Shared secret for the email-ingest → runner dispatch.
INTAKE_CLEO_INTERNAL_TOKEN=
# Public app URL the edge function uses to reach the runner. Usually equal to
# NEXT_PUBLIC_APP_URL but kept separate so you can route via a stable alias.
INTAKE_PUBLIC_APP_URL=


# ─── Supplier Portal connector B (order stream, optional) ─────────────────────
# Credentials for the supplier portal login.
RITHUM_USERNAME=
RITHUM_PASSWORD=
# Shared secret for the email-ingest → runner dispatch.
INTAKE_RITHUM_INTERNAL_TOKEN=
# Override only if the portal migrates to a new host.
RITHUM_BASE_URL=https://portal.example.com


# ─── Marketplace API connector (optional) ─────────────────────────────────────
# Credentials issued by the marketplace developer portal.
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=
# HMAC secret for webhook signature validation (set when subscribing).
WALMART_WEBHOOK_SECRET=
# Shared secret for the webhook → process dispatch.
INTAKE_WALMART_INTERNAL_TOKEN=
# Override only if the marketplace migrates the API host.
WALMART_API_BASE_URL=https://marketplace.example.com


# ════════════════════════════════════════════════════════════════════════════
# Edge Function secrets — set via `supabase secrets set <KEY>=<VALUE>`,
# NOT in this file. They live alongside the Supabase project, not your web host.
# Listed here so devs know what the Edge Functions expect.
# ════════════════════════════════════════════════════════════════════════════
# ANTHROPIC_API_KEY=                     # required for AI extraction
# INTAKE_SECRETS_KEY=                    # AES-256 key for per-tenant ERP creds
# MAILGUN_SIGNING_KEY=                   # required for Mailgun email-ingest
