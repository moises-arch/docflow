    "jsdom": "29.0.2",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "stylelint": "17.8.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "4.1.4"
  }
