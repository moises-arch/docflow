    "vaul": "1.1.2",
    "xlsx": "0.18.5",
    "zod": "4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "@sentry/cli",
      "sharp",
      "unrs-resolver",
      "msw"
    ]
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@sentry/nextjs": "10.49.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^20",
    "@types/qrcode": "1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "^9",
